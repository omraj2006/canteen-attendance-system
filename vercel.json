{
  "functions": {
    "api/index.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/signup", "destination": "/api/index.js" },
    { "source": "/login", "destination": "/api/index.js" },
    { "source": "/mark-attendance", "destination": "/api/index.js" },
    { "source": "/attendance/(.*)", "destination": "/api/index.js" },
    { "source": "/download/(.*)", "destination": "/api/index.js" },
    { "source": "/", "destination": "/frontend/pages/login.html" },
    { "source": "/pages/(.*)", "destination": "/frontend/pages/$1" },
    { "source": "/js/(.*)", "destination": "/frontend/js/$1" }
  ]
}

